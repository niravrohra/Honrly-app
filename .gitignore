# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
.pnpm-store/

# build output
/dist
/build
/out

# Tauri / Rust
/src-tauri/target
/src-tauri/gen/schemas

# release artifacts
/release
*.zip
*.app.tar.gz
