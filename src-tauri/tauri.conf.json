{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Honrly",
  "version": "0.1.0",
  "identifier": "com.honrly.honrlyapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Honrly",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' blob: data: filesystem: https://*; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*; frame-src 'self' blob: data: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    }
  }
}
