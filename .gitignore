# secrets (never commit signing keys or env files)
.env
.env.*
!.env.example
*.entitlements

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pglite-debug.log

# typescript
*.tsbuildinfo

# os
.DS_Store
